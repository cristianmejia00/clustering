),
outcome_short = c(
"Crop Yield Enhancement",
"Resource Use Efficiency",
"Soil Health & Fertility",
"GHG Mitigation",
"Water Conservation",
"Contaminant Remediation",
"Nitrogen Cycling",
"Pest & Disease Control",
"Biodiversity & Ecosystems",
"Waste Valorization",
"Economic Profitability",
